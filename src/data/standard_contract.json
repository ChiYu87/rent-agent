"""标准租房合同条款（用于对比）"""
{
  "版本": "2024标准版",
  "条款": {
    "押金": {
      "标准": "不超过1个月租金",
      "上限": "1个月租金",
      "说明": "押金应于退租时据实结算后退还"
    },
    "付款方式": {
      "标准": "押一付一 或 押一付三",
      "上限": "押一付三",
      "说明": "押二付三属于偏苛刻条款"
    },
    "中介费": {
      "标准": "半个月到1个月租金",
      "上限": "1个月租金",
      "说明": "超过1个月租金不合理"
    },
    "违约金": {
      "标准": "不超过1个月租金",
      "上限": "1个月租金",
      "说明": "违约金过高可请求法院调整"
    },
    "维修责任": {
      "标准": "自然损耗由房东承担",
      "说明": "人为损坏由租客承担"
    },
    "转租": {
      "标准": "经房东书面同意可转租",
      "说明": "完全禁止转租的条款可能无效"
    },
    "水电费": {
      "标准": "按民用标准收费",
      "说明": "商水商电需特别标注"
    },
    "提前退租": {
      "标准": "提前30天书面通知",
      "说明": "违约金通常为1个月租金"
    },
    "租期": {
      "标准": "不超过20年",
      "说明": "常见1年，可续签"
    },
    "续租优先权": {
      "标准": "同等条件下租客优先",
      "说明": "续租租金涨幅不应过大"
    },
    "房屋用途": {
      "标准": "仅限居住使用",
      "说明": "合同应明确约定房屋用途为居住"
    },
    "入住查验": {
      "标准": "入住前双方共同查验并签署验收记录",
      "说明": "入住查验是避免退租争议的关键证据"
    },
    "家具清单": {
      "标准": "列明所有家具家电品牌型号及状态",
      "说明": "无清单的押金退还纠纷难以举证"
    },
    "钥匙交接": {
      "标准": "明确钥匙门禁卡数量并签字确认",
      "说明": "钥匙交接是租赁关系成立的基本要件"
    },
    "装修约定": {
      "标准": "允许合理装修，退租时按折旧恢复",
      "说明": "完全禁止装修不合理，恢复原状应考虑折旧"
    },
    "押金退还条件": {
      "标准": "退租后7-15个工作日内退还，扣除合理费用后",
      "说明": "押金退还条件应在合同中明确约定"
    },
    "紧急维修": {
      "标准": "紧急情况24小时内响应，费用由责任方承担",
      "说明": "紧急维修关乎居住安全，应有快速处理机制"
    },
    "解约通知期": {
      "标准": "提前30天书面通知",
      "说明": "解约通知期应双方对等，不少于30天"
    },
    "房东进入权": {
      "标准": "房东进入需提前24小时通知并征得同意",
      "说明": "房东不得随意进入已出租房屋"
    }
  }
}
