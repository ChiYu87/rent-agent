"""标准租房合同条款（用于对比）"""
{
  "版本": "2024标准版",
  "条款": {
    "押金": {
      "标准": "不超过1个月租金",
      "说明": "押金应于退租时据实结算后退还"
    },
    "付款方式": {
      "标准": "押一付一 或 押一付三",
      "说明": "押二付三属于偏苛刻条款"
    },
    "中介费": {
      "标准": "半个月到1个月租金",
      "说明": "超过1个月租金不合理"
    },
    "违约金": {
      "标准": "不超过1个月租金",
      "说明": "违约金过高可请求法院调整"
    },
    "维修责任": {
      "标准": "自然损耗由房东承担",
      "说明": "人为损坏由租客承担"
    },
    "转租": {
      "标准": "经房东书面同意可转租",
      "说明": "完全禁止转租的条款可能无效"
    },
    "水电费": {
      "标准": "按民用标准收费",
      "说明": "商水商电需特别标注"
    },
    "提前退租": {
      "标准": "提前30天书面通知",
      "说明": "违约金通常为1个月租金"
    },
    "租期": {
      "标准": "不超过20年",
      "说明": "常见1年，可续签"
    },
    "续租优先权": {
      "标准": "同等条件下租客优先",
      "说明": "续租租金涨幅不应过大"
    }
  }
}
